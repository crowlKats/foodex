{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "migrate": "deno run -A db/migrate.ts"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@^2.2.0",
    "preact": "npm:preact@^10.29.0",
    "@preact/signals": "npm:@preact/signals@^2.8.2",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "vite": "npm:vite@^7.3.1",
    "tailwindcss": "npm:tailwindcss@^4.2.2",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.2",
    "pg": "npm:pg@^8.20.0",
    "@types/pg": "npm:@types/pg@^8.20.0",
    "marked": "npm:marked@^15.0.12",
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3.1014.0",
    "@aws-sdk/s3-request-presigner": "npm:@aws-sdk/s3-request-presigner@^3.1014.0",
    "tb-icons": "jsr:@preact-icons/tb@^1.0.14",
    "@anthropic-ai/sdk": "npm:@anthropic-ai/sdk@^0.52.0",
    "barcode-detector": "npm:barcode-detector@^3.0.3",
    "zxing-wasm/reader": "npm:zxing-wasm@^3.0.1/reader"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  },
  "unstable": [
    "cron"
  ],
  "deploy": {
    "org": "crowlkats",
    "app": "foodex"
  }
}
